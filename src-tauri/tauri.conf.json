{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bd board",
  "version": "0.1.0",
  "identifier": "com.jeanpfs.bdboard",
  "mainBinaryName": "bd-board",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm desktop:prepare",
    "devUrl": "http://localhost:3009",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "bd board",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
