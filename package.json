{
  "name": "bd-board",
  "version": "0.1.0",
  "description": "Local visual board and multi-project dashboard for the bd beads issue tracker.",
  "private": false,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jeanpfs/bd-board.git"
  },
  "bugs": {
    "url": "https://github.com/jeanpfs/bd-board/issues"
  },
  "homepage": "https://github.com/jeanpfs/bd-board#readme",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3009",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview --port 3009",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "audit:prod": "pnpm audit --prod",
    "validate": "pnpm typecheck && pnpm check && pnpm exec eslint --max-warnings=0 && pnpm test && pnpm audit:prod"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@fontsource-variable/geist": "5.2.9",
    "@fontsource-variable/geist-mono": "5.2.8",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.25",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "lucide-react": "0.545.0",
    "nitro": "npm:nitro-nightly@3.0.1-20260608-212106-c6607d99",
    "radix-ui": "1.5.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "10.1.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/router-cli": "1.167.17",
    "@tanstack/router-plugin": "1.168.18",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.20",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "cmdk": "1.1.1",
    "eslint": "10.4.1",
    "jsdom": "28.1.0",
    "prettier": "3.8.3",
    "shadcn": "4.11.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
